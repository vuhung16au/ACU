<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Async Unit Testing Demo</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <p class="site-kicker">ITEC323</p>
            <h1 class="site-title">Async Unit Testing Demo</h1>
            <p class="site-subtitle">A follow-up unit testing project that keeps the same form but makes the duplicate-email check asynchronous.</p>
        </div>
    </header>

    <main class="container content-area">
        @RenderBody()
    </main>
</body>
</html>
