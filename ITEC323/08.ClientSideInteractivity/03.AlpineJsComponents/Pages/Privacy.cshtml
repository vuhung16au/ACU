@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<section class="hero-panel hero-panel-compact">
    <span class="eyebrow">Local Classroom App</span>
    <h1>Privacy and data use</h1>
    <p class="lead mb-0">
        This Alpine.js sample keeps all interactive data in the current browser session.
        No personal information is sent to third-party services.
    </p>
</section>

<section class="info-panel">
    <h2>What this means in practice</h2>
    <ul>
        <li>Todo and form examples are local-only and reset on refresh.</li>
        <li>No cookies or analytics scripts are included.</li>
        <li>Razor Pages still controls server rendering and routing.</li>
    </ul>
</section>
