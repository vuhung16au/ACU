<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 04.HtmxPartialUpdates</title>
    <!-- HTMX enables partial page updates via HTML attributes — no custom JavaScript needed. -->
    <script src="https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container shell-header">
            <a class="brand" asp-page="/Index">04.HtmxPartialUpdates</a>
            <nav class="site-nav" aria-label="Main navigation">
                <a asp-page="/Index">Home</a>
                <a asp-page="/HtmxLab">HTMX Lab</a>
                <a asp-page="/Privacy">Privacy</a>
            </nav>
        </div>
    </header>

    <main class="container page-content" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            Week 8 client-side interactivity sample focused on HTMX partial page updates.
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
