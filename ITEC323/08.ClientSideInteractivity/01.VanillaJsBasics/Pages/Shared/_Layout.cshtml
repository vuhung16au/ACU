<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 01.VanillaJsBasics</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container shell-header">
            <a class="brand" asp-page="/Index">01.VanillaJsBasics</a>
            <nav class="site-nav" aria-label="Main navigation">
                <a asp-page="/Index">Home</a>
                <a asp-page="/Playground">Playground</a>
                <a asp-page="/Privacy">Privacy</a>
            </nav>
        </div>
    </header>

    <main class="container page-content" role="main">
            @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            Week 8 client-side interactivity sample with modern vanilla JavaScript.
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
