@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<section class="hero-panel hero-panel-compact">
    <span class="eyebrow">Local Classroom App</span>
    <h1>Privacy and data use</h1>
    <p class="lead mb-0">
        This sample stores demonstration data only in the browser page memory.
        No personal data is sent to third-party services.
    </p>
</section>

<section class="info-panel">
    <h2>What this means in practice</h2>
    <ul>
        <li>Form entries are used only to update the current page view.</li>
        <li>Reloading the page resets demo data to keep exercises repeatable.</li>
        <li>No cookies or analytics scripts are included in this project.</li>
    </ul>
</section>
