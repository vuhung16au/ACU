@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<section class="hero-panel hero-panel-compact">
    <span class="eyebrow">Local Classroom App</span>
    <h1>Privacy and data use</h1>
    <p class="lead mb-0">
        This module uses local in-memory sample data for learning async communication.
        No personal information is sent to third-party services.
    </p>
</section>

<section class="info-panel">
    <h2>What this means in practice</h2>
    <ul>
        <li>Session entries are sample classroom data only.</li>
        <li>Data resets when the application restarts.</li>
        <li>No analytics scripts or tracking cookies are used.</li>
    </ul>
</section>
