@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<h1>@ViewData["Title"]</h1>

<p>This is a sample privacy policy page for the Razor Pages Essentials educational project.</p>

<p>In a real application, this page would contain information about:</p>
<ul>
    <li>What data your application collects</li>
    <li>How the data is used</li>
    <li>How the data is protected</li>
    <li>User rights regarding their data</li>
    <li>Contact information for privacy concerns</li>
</ul>
