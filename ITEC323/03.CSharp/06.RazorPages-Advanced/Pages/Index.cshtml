@page
@model IndexModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="text-center">
    <h1 class="display-4">@Localizer["Title"]</h1>
    <p>@Localizer["Description"]</p>
</div>

<div class="user-table-container">
    <table class="user-table">
        <thead>
            <tr>
                <th>@Localizer["ID"]</th>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Email"]</th>
                <th>@Localizer["Country"]</th>
                <th>@Localizer["CreatedDate"]</th>
            </tr>
        </thead>
        <tbody>
            @* @foreach loop iterates through all users from the database *@
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Country</td>
                    <td>@user.CreatedDate.ToString("MMM dd, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Users.Count == 0)
    {
        <p class="no-users">@Localizer["NoUsers"]</p>
    }
    else
    {
        <p class="user-count">@Localizer["TotalUsers"]: @Model.Users.Count</p>
    }
</div>

<div class="json-demo">
    <h2>@Localizer["JsonTitle"]</h2>
    <p>@Localizer["JsonDescription"]</p>
    <pre><code>@System.Text.Json.JsonSerializer.Serialize(Model.Users, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</code></pre>
</div>
