<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gemini RAG Razor</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <p class="site-kicker">32-AI-Integration</p>
            <h1 class="site-title">Gemini Text And RAG Chat</h1>
            <p class="site-subtitle">A Razor Pages interface for asking grounded questions against a small local knowledge base.</p>
        </div>
    </header>

    <main class="container content-area">
        @RenderBody()
    </main>
</body>
</html>
