@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Product Details";
}

<h1 class="h3">Product Details</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Product.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Product.Description</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Product.Price.ToString("C")</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">@Model.Product.StockQuantity</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Product.Category?.Name</dd>

            <dt class="col-sm-3">Created (UTC)</dt>
            <dd class="col-sm-9">@Model.Product.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-page="Edit" asp-route-id="@Model.Product.Id" class="btn btn-primary">Edit</a>
    <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
