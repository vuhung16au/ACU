@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Category Details";
}

<h1 class="h3">@Model.Category.Name</h1>
<p class="text-muted">Products in this category: @Model.Category.Products.Count</p>

@if (!Model.Category.Products.Any())
{
    <div class="alert alert-info">This category does not have any products yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Stock</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Category.Products)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Price.ToString("C")</td>
                        <td>@product.StockQuantity</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-page="Edit" asp-route-id="@Model.Category.Id" class="btn btn-primary">Edit</a>
    <a asp-page="Index" class="btn btn-outline-secondary">Back to Categories</a>
</div>