@page
@model ScaffoldingCRUD.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Products</h1>
    <a asp-page="Create" class="btn btn-primary">Create New Product</a>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">
        No products found yet. Create your first product to test EF Core persistence.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Created (UTC)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Category?.Name</td>
                        <td>@product.Price.ToString("C")</td>
                        <td>@product.StockQuantity</td>
                        <td>@product.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a asp-page="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-page="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
