@page
@model GridModel
@{
    ViewBag.Title = "Layout Utilities";
}

<h1 class="text-3xl font-bold text-slate-900">Tailwind Layout Utilities</h1>
<div class="mt-4 rounded-lg border border-sky-200 bg-sky-50 p-4 text-sky-900">
    <strong>Utility-first layout:</strong> Tailwind uses classes like <code>grid</code>, <code>md:grid-cols-3</code>, and <code>gap-4</code>.
</div>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Equal Columns</h2>
    <div class="mt-3 grid gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">Column 1</div>
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">Column 2</div>
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">Column 3</div>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">2/3 + 1/3 Split</h2>
    <div class="mt-3 grid gap-3 md:grid-cols-12">
        <div class="rounded-lg bg-sky-600 p-4 text-center text-white md:col-span-8">md:col-span-8</div>
        <div class="rounded-lg bg-slate-700 p-4 text-center text-white md:col-span-4">md:col-span-4</div>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Responsive Breakpoints</h2>
    <p class="mt-2 text-slate-600">Resize browser width to observe `sm`, `md`, and `lg` changes.</p>
    <div class="mt-3 grid gap-3 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        <div class="rounded-lg bg-amber-100 p-4 text-center text-amber-900">1 / 2 / 3 / 4</div>
        <div class="rounded-lg bg-amber-100 p-4 text-center text-amber-900">1 / 2 / 3 / 4</div>
        <div class="rounded-lg bg-amber-100 p-4 text-center text-amber-900">1 / 2 / 3 / 4</div>
        <div class="rounded-lg bg-amber-100 p-4 text-center text-amber-900">1 / 2 / 3 / 4</div>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Nested Grid</h2>
    <div class="mt-3 grid gap-3 md:grid-cols-12">
        <div class="rounded-lg bg-cyan-700 p-4 text-white md:col-span-8">
            Parent: md:col-span-8
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
                <div class="rounded bg-white p-3 text-center text-cyan-900">Nested 1</div>
                <div class="rounded bg-white p-3 text-center text-cyan-900">Nested 2</div>
            </div>
        </div>
        <div class="rounded-lg bg-cyan-700 p-4 text-center text-white md:col-span-4">Sidebar: md:col-span-4</div>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Alignment Utilities</h2>
    <div class="mt-3 grid min-h-32 place-items-center rounded-lg border border-rose-200 bg-rose-50">
        <span class="rounded bg-rose-600 px-3 py-2 text-white">Centered with place-items-center</span>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Breakpoint Reference</h2>
    <div class="mt-3 overflow-x-auto rounded-xl border border-slate-200 bg-white">
        <table class="min-w-full text-left text-sm">
            <thead class="bg-slate-100 text-slate-700">
                <tr>
                    <th class="px-4 py-3">Prefix</th>
                    <th class="px-4 py-3">Min Width</th>
                    <th class="px-4 py-3">Example</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-slate-700">
                <tr><td class="px-4 py-3"><code>sm:</code></td><td class="px-4 py-3">640px</td><td class="px-4 py-3"><code>sm:grid-cols-2</code></td></tr>
                <tr><td class="px-4 py-3"><code>md:</code></td><td class="px-4 py-3">768px</td><td class="px-4 py-3"><code>md:grid-cols-3</code></td></tr>
                <tr><td class="px-4 py-3"><code>lg:</code></td><td class="px-4 py-3">1024px</td><td class="px-4 py-3"><code>lg:grid-cols-4</code></td></tr>
                <tr><td class="px-4 py-3"><code>xl:</code></td><td class="px-4 py-3">1280px</td><td class="px-4 py-3"><code>xl:px-12</code></td></tr>
                <tr><td class="px-4 py-3"><code>2xl:</code></td><td class="px-4 py-3">1536px</td><td class="px-4 py-3"><code>2xl:max-w-7xl</code></td></tr>
            </tbody>
        </table>
    </div>
</section>
