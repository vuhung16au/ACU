@page
@model ComponentsModel
@{
    ViewBag.Title = "Components";
}

<h1 class="text-3xl font-bold text-slate-900">Tailwind Components</h1>
<p class="mt-2 text-slate-600">These are common UI patterns created with Tailwind utility classes.</p>

<section class="mt-8 space-y-3">
    <h2 class="text-xl font-semibold">Alerts</h2>
    <div class="rounded-lg border border-sky-200 bg-sky-50 px-4 py-3 text-sky-800">Info alert: Tailwind classes are composable.</div>
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800">Success alert: Great work.</div>
    <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800">Warning alert: Review breakpoints.</div>
    <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-rose-800">Error alert: Something failed.</div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Buttons</h2>
    <div class="mt-3 flex flex-wrap gap-3">
        <button class="rounded-lg bg-sky-600 px-4 py-2 text-white hover:bg-sky-700">Primary</button>
        <button class="rounded-lg bg-slate-700 px-4 py-2 text-white hover:bg-slate-800">Secondary</button>
        <button class="rounded-lg bg-emerald-600 px-4 py-2 text-white hover:bg-emerald-700">Success</button>
        <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-slate-700 hover:bg-slate-50">Outline</button>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Cards</h2>
    <div class="mt-3 grid gap-4 md:grid-cols-3">
        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <h3 class="font-semibold">Simple Card</h3>
            <p class="mt-2 text-sm text-slate-600">Use spacing, border, shadow, and typography utilities.</p>
        </article>
        <article class="rounded-xl border border-sky-200 bg-sky-50 p-5 shadow-sm">
            <h3 class="font-semibold text-sky-900">Featured Card</h3>
            <p class="mt-2 text-sm text-sky-800">Accent colors help highlight important content.</p>
        </article>
        <article class="rounded-xl border border-emerald-200 bg-emerald-50 p-5 shadow-sm">
            <h3 class="font-semibold text-emerald-900">Success Card</h3>
            <p class="mt-2 text-sm text-emerald-800">Semantic colors can communicate state clearly.</p>
        </article>
    </div>
</section>

<section class="mt-8 grid gap-6 md:grid-cols-2">
    <div>
        <h2 class="text-xl font-semibold">Badges</h2>
        <div class="mt-3 flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-sky-100 px-3 py-1 text-sm font-medium text-sky-800">New</span>
            <span class="rounded-full bg-rose-100 px-3 py-1 text-sm font-medium text-rose-800">Hot</span>
            <span class="rounded-full bg-slate-200 px-3 py-1 text-sm font-medium text-slate-700">Draft</span>
        </div>
    </div>
    <div>
        <h2 class="text-xl font-semibold">List Group</h2>
        <ul class="mt-3 overflow-hidden rounded-xl border border-slate-200 bg-white">
            <li class="border-b border-slate-200 px-4 py-3">Active item</li>
            <li class="border-b border-slate-200 px-4 py-3">Second item</li>
            <li class="border-b border-slate-200 px-4 py-3">Third item</li>
            <li class="px-4 py-3 text-slate-400">Disabled item</li>
        </ul>
    </div>
</section>

<section class="mt-8">
    <h2 class="text-xl font-semibold">Form Example</h2>
    <form class="mt-3 grid gap-4 md:grid-cols-2">
        <div>
            <label for="firstName" class="block text-sm font-medium text-slate-700">First Name</label>
            <input id="firstName" type="text" placeholder="John" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" />
        </div>
        <div>
            <label for="lastName" class="block text-sm font-medium text-slate-700">Last Name</label>
            <input id="lastName" type="text" placeholder="Doe" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" />
        </div>
        <div class="md:col-span-2">
            <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
            <input id="email" type="email" placeholder="john.doe@example.com" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" />
        </div>
        <div class="md:col-span-2 flex items-center gap-2">
            <input id="newsletter" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" />
            <label for="newsletter" class="text-sm text-slate-700">Send me newsletters</label>
        </div>
        <div class="md:col-span-2 flex gap-3">
            <button type="submit" class="rounded-lg bg-sky-600 px-4 py-2 text-white hover:bg-sky-700">Submit</button>
            <button type="reset" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-slate-700 hover:bg-slate-50">Reset</button>
        </div>
    </form>
</section>
