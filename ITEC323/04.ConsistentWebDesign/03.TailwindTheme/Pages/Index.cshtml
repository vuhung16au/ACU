@page
@model IndexModel
@{
    ViewBag.Title = "Home";
}

<section class="rounded-xl bg-sky-700 px-6 py-10 text-white shadow-lg">
    <h1 class="text-3xl font-bold sm:text-4xl">Tailwind CSS Integration</h1>
    <p class="mt-3 text-sky-100">
        Learn utility-first styling in ASP.NET Core Razor Pages using Tailwind CSS via CDN.
    </p>
    <p class="mt-4 text-sm text-sky-100">
        This project mirrors BootstrapTheme, but uses Tailwind utility classes for layout, spacing, and components.
    </p>
</section>

<section class="mt-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-slate-900">Key Learning Points</h2>
    <ul class="mt-4 space-y-3 text-slate-700">
        <li class="rounded-lg bg-slate-50 p-3"><strong>CDN setup:</strong> Add the Tailwind CDN script in `_Layout.cshtml`.</li>
        <li class="rounded-lg bg-slate-50 p-3"><strong>Utility-first:</strong> Style directly with classes like `px-6`, `rounded-xl`, `text-slate-700`.</li>
        <li class="rounded-lg bg-slate-50 p-3"><strong>Responsive design:</strong> Use breakpoints such as `sm:`, `md:`, and `lg:`.</li>
        <li class="rounded-lg bg-slate-50 p-3"><strong>Reusable layout:</strong> Keep shared nav/footer in one layout file.</li>
    </ul>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-2">
    <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold">Component Examples</h3>
        <p class="mt-2 text-slate-600">See cards, badges, alerts, forms, and buttons built with Tailwind classes.</p>
        <a href="/Components" class="mt-4 inline-flex rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">View Components</a>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold">Layout Utilities</h3>
        <p class="mt-2 text-slate-600">Practice grids, responsive breakpoints, nested layouts, and alignment tools.</p>
        <a href="/Grid" class="mt-4 inline-flex rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">Explore Layout</a>
    </article>
</section>

<section class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-6">
    <h2 class="text-lg font-semibold text-amber-900">CDN vs Build Pipeline</h2>
    <p class="mt-2 text-amber-800">
        This demo uses Tailwind CDN for simplicity. In production, prefer a build pipeline to tree-shake unused classes and reduce CSS size.
    </p>
</section>
