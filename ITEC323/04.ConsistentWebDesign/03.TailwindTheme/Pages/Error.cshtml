@page
@model ErrorModel
@{
    ViewBag.Title = "Error";
}

<div class="mx-auto max-w-xl rounded-xl border border-rose-200 bg-rose-50 p-8 text-center">
    <p class="text-4xl font-bold text-rose-700">Error</p>
    <h1 class="mt-3 text-3xl font-bold text-rose-900">Error</h1>
    <p class="mt-2 text-rose-800">An error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-4 text-sm text-rose-900">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a href="/" class="mt-6 inline-flex rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">
        Return Home
    </a>
</div>
