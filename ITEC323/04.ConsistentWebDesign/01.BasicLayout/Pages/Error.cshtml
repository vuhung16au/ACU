@page
@model ErrorModel
@{
    ViewBag.Title = "Error";
}

<div class="page-content">
    <h2>Error</h2>
    <p>An error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="info-box">
        <h3>💡 Layout Note</h3>
        <p>
            Even the error page uses the layout! Consistent user experience everywhere.
        </p>
    </div>
</div>
