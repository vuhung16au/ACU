<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShellNavigation.Views.DetailPage"
             Title="Task Detail">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Detail Route"
                   Style="{StaticResource SubHeadline}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="{Binding StatusMessage, Mode=OneWay}"
                   FontSize="16"
                   AutomationId="DetailStatusLabel" />

            <Label Text="Title" FontAttributes="Bold" />
            <Label Text="{Binding Title, Mode=OneWay}"
                   FontSize="18"
                   AutomationId="DetailTitleLabel" />

            <Label Text="Description" FontAttributes="Bold" />
            <Label Text="{Binding Description, Mode=OneWay}"
                   AutomationId="DetailDescriptionLabel" />

            <Label Text="{Binding IsCompleted, StringFormat='Completed: {0}'}"
                   AutomationId="DetailCompletedLabel" />

            <Button Text="Edit Task"
                    Command="{Binding EditCommand}"
                    AutomationId="GoToEditButton" />

            <Button Text="Back To List"
                    Command="{Binding GoBackCommand}"
                    AutomationId="BackFromDetailButton" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
