@model IReadOnlyList<HtmxPartialRendering.Models.CheckInMessage>

@if (Model.Count == 0)
{
    <p class="empty-state">No reflections have been posted yet.</p>
}
else
{
    <div class="stack-list">
    @foreach (var item in Model)
    {
        @await Html.PartialAsync("~/Views/Shared/Fragments/_ReflectionEntry.cshtml", item)
    }
    </div>
}
