<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 03.HtmxPartialRendering</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container shell-header">
            <a class="brand" asp-page="/Index">03.HtmxPartialRendering</a>
            <nav class="site-nav">
                <a asp-page="/Index">Home</a>
                <a asp-page="/HtmxBoard">HTMX Board</a>
                <a asp-page="/Privacy">Privacy</a>
            </nav>
        </div>
    </header>

    <main class="container page-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            Week 7 example showing HTMX-style partial rendering with server-returned HTML fragments.
        </div>
    </footer>

    <script src="~/js/htmx-lite.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
