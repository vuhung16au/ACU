@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<section class="hero-panel hero-panel-compact">
    <span class="eyebrow">Privacy And Scope</span>
    <h1>This weather dashboard uses only local mock data.</h1>
    <p class="lead mb-0">
        The dashboard does not call any external weather service. All values are simulated inside the app for learning purposes.
    </p>
</section>

<section class="card-grid">
    <article class="info-card">
        <h2>Local Simulation</h2>
        <ul>
            <li>No API keys are required.</li>
            <li>No internet connection is required.</li>
            <li>Data changes are generated by the local simulation service.</li>
        </ul>
    </article>

    <article class="info-card">
        <h2>Teaching Focus</h2>
        <ul>
            <li>This project teaches polling and dashboard refresh patterns.</li>
            <li>The data is intentionally simple so students can focus on the Fetch API workflow.</li>
            <li>The page demonstrates both manual and automatic refresh techniques.</li>
        </ul>
    </article>
</section>
