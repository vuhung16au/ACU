<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Efficient LINQ</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-shell">
        <div class="shell-inner">
            <div>
                <p class="site-kicker">ITEC323 • 40-Advanced-EFCore</p>
                <h1>Efficient LINQ</h1>
                <p class="site-subtitle">Projection, filtering, paging, and SQL inspection for EF Core with PostgreSQL.</p>
            </div>
            <nav class="top-nav">
                <a asp-page="/Index">Overview</a>
                <a asp-page="/QueryLab/Index">Query Lab</a>
                <a asp-page="/Products/Index">Products</a>
            </nav>
        </div>
    </header>

    <main class="page-shell">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
