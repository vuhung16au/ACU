@page "{id:int}"
@model EditModel
@{
    ViewData["Title"] = "Edit";
    ViewData["PageName"] = "Edit User";
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="alert-panel">
        <h2 class="h5">Edit Error</h2>
        <p class="mb-0">@Model.ErrorMessage</p>
    </section>
}
else
{
    <section class="hero-panel hero-panel-compact mb-4">
        <span class="eyebrow">Edit User</span>
        <h1>Update the selected record and rewrite the CSV file.</h1>
        <p class="lead mb-0">This page reuses the same user form partial used by the create page.</p>
    </section>

    <section class="form-panel">
        <h2 class="h4">Edit User Form</h2>
        <form method="post">
            <input type="hidden" asp-for="UserInput.Id" />
            <div asp-validation-summary="All" class="validation-summary-errors mb-3"></div>
            <partial name="_UserForm" for="UserInput" />
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a class="btn btn-outline-secondary" asp-page="/Details" asp-route-id="@Model.UserInput.Id">Cancel</a>
        </form>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
