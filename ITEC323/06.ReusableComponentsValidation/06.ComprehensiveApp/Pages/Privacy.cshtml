@page
@model PrivacyModel
@{
    ViewData["Title"] = "Notes";
    ViewData["PageName"] = "Notes";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Extra Notes</span>
    <h1>Every layer of the app has a separate job.</h1>
    <p class="lead mb-0">Models validate, services manage CSV data, partials reuse markup, and view components prepare sidebar data.</p>
</section>

<section class="info-panel">
    <h2 class="h5">Architecture reminder</h2>
    <ul class="mb-0">
        <li>PageModels coordinate requests.</li>
        <li>Services read and write the CSV file.</li>
        <li>Partials avoid duplicated Razor markup.</li>
        <li>View components keep sidebar logic out of pages and layouts.</li>
    </ul>
</section>
