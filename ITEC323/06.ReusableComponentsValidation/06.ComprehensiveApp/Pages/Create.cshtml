@page
@model CreateModel
@{
    ViewData["Title"] = "Create";
    ViewData["PageName"] = "Create User";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Create User</span>
    <h1>Add a new CSV-backed user record.</h1>
    <p class="lead mb-0">This form reuses the shared user fields partial and validates everything before saving.</p>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="alert-panel mb-4">
        <h2 class="h5">Save Error</h2>
        <p class="mb-0">@Model.ErrorMessage</p>
    </section>
}

<section class="form-panel">
    <h2 class="h4">New User Form</h2>
    <form method="post">
        <div asp-validation-summary="All" class="validation-summary-errors mb-3"></div>
        <partial name="_UserForm" for="UserInput" />
        <button type="submit" class="btn btn-primary">Create User</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
