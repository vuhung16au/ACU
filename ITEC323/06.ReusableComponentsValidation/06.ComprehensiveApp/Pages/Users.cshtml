@page
@model UsersModel
@{
    ViewData["Title"] = "Users";
    ViewData["PageName"] = "Users";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">User Directory</span>
    <h1>Read every user from the CSV file.</h1>
    <p class="lead mb-0">This page combines a quick card layout with a detailed table so students can compare UI options.</p>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="alert-panel">
        <h2 class="h5">File Error</h2>
        <p class="mb-0">@Model.ErrorMessage</p>
    </section>
}
else
{
    <section class="mb-4">
        <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <div>
                <h2 class="h4 mb-1">User Cards</h2>
                <p class="text-muted mb-0">Rendered with the reusable <code>_UserCard.cshtml</code> partial.</p>
            </div>
            <a class="btn btn-primary" asp-page="/Create">Add User</a>
        </div>

        <div class="user-grid">
            @foreach (var user in Model.Users)
            {
                <partial name="_UserCard" model="user" />
            }
        </div>
    </section>

    <section class="detail-panel">
        <h2 class="h4 mb-3">Detailed Table</h2>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Date of Birth</th>
                        <th>Age</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@user.Phone</td>
                        <td>@user.DateOfBirth?.ToString("dd MMM yyyy")</td>
                        <td>@user.Age</td>
                        <td class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-primary" asp-page="/Details" asp-route-id="@user.Id">Details</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Edit" asp-route-id="@user.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="/Delete" asp-route-id="@user.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}
