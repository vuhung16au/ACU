@model List<ComprehensiveAppDemo.Models.User>

<section class="sidebar-card">
    <h2 class="h5 mb-3">Recent Activity</h2>

    @if (Model.Count == 0)
    {
        <p class="mb-0">No recent activity yet.</p>
    }
    else
    {
        <ul class="list-unstyled mb-0">
        @foreach (var user in Model)
        {
            <li class="mb-3">
                <strong>@user.Name</strong>
                <div class="text-muted small">@user.RecentActivity</div>
            </li>
        }
        </ul>
    }
</section>
