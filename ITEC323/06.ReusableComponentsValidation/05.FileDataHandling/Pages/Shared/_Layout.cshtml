<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - File Data Handling Demo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container py-4">
        <header class="site-header">
            <div>
                <a class="site-title" asp-page="/Index">File Data Handling Demo</a>
                <div class="text-muted">Read and write CSV data with async file operations and validation</div>
            </div>

            <nav aria-label="Main navigation">
                <a asp-page="/Index">Home</a>
                <a asp-page="/Users">Users</a>
                <a asp-page="/Create">Add User</a>
            </nav>
        </header>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                @* <span>&copy; 2026 ACU ITEC323 File Data Handling example</span> *@
                <span>CSV paths use <code>Path.Combine</code> and file access uses async methods.</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
