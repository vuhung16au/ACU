@page
@model UsersModel
@{
    ViewData["Title"] = "Users";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">User List</span>
    <h1>Read user records from a CSV file.</h1>
    <p class="lead mb-0">The table below is populated with <code>File.ReadAllLinesAsync()</code> and simple CSV parsing.</p>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="alert-panel mb-4">
        <h2 class="h5">File Error</h2>
        <p class="mb-0">@Model.ErrorMessage</p>
    </section>
}
else
{
    <section class="table-panel">
        <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <div>
                <h2 class="h4 mb-1">Stored Users</h2>
                <p class="text-muted mb-0">Dates are formatted consistently and age is calculated in the model.</p>
            </div>
            <a class="btn btn-primary" asp-page="/Create">Add User</a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Date of Birth</th>
                        <th>Age</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@user.Phone</td>
                        <td>@user.DateOfBirth?.ToString("dd MMM yyyy")</td>
                        <td>@user.Age</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}
