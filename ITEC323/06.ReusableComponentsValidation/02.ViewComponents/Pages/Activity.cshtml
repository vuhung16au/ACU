@page
@model ActivityModel
@{
    ViewData["Title"] = "Activity";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Activity Page</span>
    <h1>Reuse the same components with different parameters.</h1>
    <p class="lead mb-0">Changing the values passed to the tag helper changes the data each component renders.</p>
</section>

<div class="row g-3">
    <div class="col-lg-6">
        <vc:user-profile user-id="@Model.SecondUserId"></vc:user-profile>
    </div>
    <div class="col-lg-6">
        <vc:recent-items user-id="@Model.SecondUserId" max-items="4"></vc:recent-items>
    </div>
</div>
