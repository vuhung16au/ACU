@page
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Dashboard Page</span>
    <h1>Pass parameters into view components to render user-specific content.</h1>
    <p class="lead mb-0">This page shows the cart, profile, and recent items for user <strong>@Model.UserId</strong>.</p>
</section>

<div class="row g-3">
    <div class="col-lg-4">
        <vc:shopping-cart></vc:shopping-cart>
    </div>
    <div class="col-lg-4">
        <vc:user-profile user-id="@Model.UserId"></vc:user-profile>
    </div>
    <div class="col-lg-4">
        <vc:recent-items user-id="@Model.UserId" max-items="2"></vc:recent-items>
    </div>
</div>
