@model List<ViewComponentsDemo.Models.RecentItem>

<section class="component-card">
    <h2 class="h5 component-title">Recent Items</h2>

    @if (Model.Count == 0)
    {
        <p class="mb-0">No recent items were found for this user.</p>
    }
    else
    {
        <ul class="item-list">
            @foreach (var item in Model)
            {
                <li>
                    <div class="d-flex justify-content-between gap-3">
                        <strong>@item.Title</strong>
                        <span class="muted-label">@item.HoursAgo h ago</span>
                    </div>
                    <div class="muted-label">@item.Category</div>
                </li>
            }
        </ul>
    }
</section>
