@page
@model PrivacyModel
@{
    ViewData["Title"] = "Notes";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Extra Notes</span>
    <h1>Advanced validation reduces bad data, but output encoding reduces bad outcomes.</h1>
    <p class="lead mb-0">Validation and security should work together, not as separate ideas.</p>
</section>

<section class="info-panel">
    <h2 class="h5">Remember</h2>
    <ul class="mb-0">
        <li>Regular expressions are useful when a format must be exact.</li>
        <li>Custom validators are useful when rules depend on calculations.</li>
        <li>Validated input can still be dangerous if it is rendered unsafely.</li>
    </ul>
</section>
