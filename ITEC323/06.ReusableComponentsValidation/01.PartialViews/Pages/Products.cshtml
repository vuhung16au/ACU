@page
@model ProductsModel
@{
    ViewData["Title"] = "Products";
}

<partial name="_Header" />

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Products Page</span>
    <h1>Render the same partial for every product.</h1>
    <p class="lead mb-0">This page loops through a collection and passes each product into the same partial view.</p>
</section>

<div class="row g-3">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-6 col-xl-4">
            <partial name="_ProductCard" model="product" />
        </div>
    }
</div>

<partial name="_Footer" />
