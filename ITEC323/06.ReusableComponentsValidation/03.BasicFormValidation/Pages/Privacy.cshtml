@page
@model PrivacyModel
@{
    ViewData["Title"] = "Notes";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Extra Notes</span>
    <h1>Validation rules live in the model so every form uses the same source of truth.</h1>
    <p class="lead mb-0">Keep validation messages clear and beginner-friendly.</p>
</section>

<section class="info-panel">
    <h2 class="h5">Remember</h2>
    <ul class="mb-0">
        <li>Client-side validation improves feedback speed.</li>
        <li>Server-side validation is the final safety check.</li>
        <li>Validation summaries help users understand all problems at once.</li>
    </ul>
</section>
