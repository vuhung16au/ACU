@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="hero-panel hero-panel-compact mb-4">
    <span class="eyebrow">Registration Form</span>
    <h1>Use Data Annotations to validate a user model.</h1>
    <p class="lead mb-0">Try submitting the form with empty or invalid values to see inline errors and the summary update.</p>
</section>

<section class="form-panel mb-4">
    <h2 class="h4">Create Account</h2>
    <p>These rules are defined in the <code>UserRegistration</code> model and checked with <code>ModelState.IsValid</code>.</p>

    <form method="post" novalidate>
        <div asp-validation-summary="All" class="validation-summary-errors mb-3"></div>

        <div class="mb-3">
            <label asp-for="Registration.FullName" class="form-label"></label>
            <input asp-for="Registration.FullName" class="form-control" />
            <span asp-validation-for="Registration.FullName" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Registration.Email" class="form-label"></label>
            <input asp-for="Registration.Email" class="form-control" />
            <span asp-validation-for="Registration.Email" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Registration.Phone" class="form-label"></label>
            <input asp-for="Registration.Phone" class="form-control" />
            <span asp-validation-for="Registration.Phone" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Registration.Age" class="form-label"></label>
            <input asp-for="Registration.Age" class="form-control" />
            <span asp-validation-for="Registration.Age" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn btn-primary">Submit Registration</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <section class="result-panel">
        <h2 class="h5">Success</h2>
        <p class="mb-0">@Model.SuccessMessage</p>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
