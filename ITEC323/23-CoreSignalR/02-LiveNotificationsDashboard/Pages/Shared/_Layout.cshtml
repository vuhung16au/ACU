<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 02-LiveNotificationsDashboard</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_02_LiveNotificationsDashboard.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="site-header">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">02-LiveNotificationsDashboard</a>
                <ul class="site-nav">
                    <li><a class="nav-link" asp-area="" asp-page="/Index">Home</a></li>
                    <li><a class="nav-link" asp-area="" asp-page="/Privacy">Privacy</a></li>
                </ul>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            ASP.NET Core SignalR live dashboard demo for ITEC323.
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
