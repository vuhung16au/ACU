@using RazorPagesHelloWorld
@using RazorPagesHelloWorld.Pages
@using Microsoft.AspNetCore.Mvc.RazorPages

@* 
    ============================================================================
    _ViewImports.cshtml
    ============================================================================
    
    This file contains common using directives that are available to all
    Razor Pages in the application.
    
    Key Concepts:
    - @using: Import namespaces (like 'using' in C#)
    - All pages automatically have access to these namespaces
    - Reduces repetition - don't need to add @using in every .cshtml file
    
    Without this file, you'd need to write:
        @Model.PropertyName              (won't work)
    
    With this file, you can write:
        @Model.PropertyName              (works!)
        
    ============================================================================
*@
