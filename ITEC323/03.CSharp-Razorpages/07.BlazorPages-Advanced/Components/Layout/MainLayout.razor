@inherits LayoutComponentBase

<div class="page">
    <header>
        <nav class="navbar">
            <div class="container">
                <a class="navbar-brand" href="/">Blazor Advanced</a>
                <NavMenu />
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @Body
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; @DateTime.Now.Year - Blazor Advanced - <a href="/privacy">Privacy</a>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred. <a href="" class="reload">Reload</a> <span class="dismiss">🗙</span>
</div>
