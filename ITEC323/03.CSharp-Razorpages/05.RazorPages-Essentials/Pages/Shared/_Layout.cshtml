<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Razor Pages Essentials</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <a asp-page="/Index" class="navbar-brand">Razor Pages Essentials</a>
                <ul class="nav-menu">
                    <li><a asp-page="/Index">Home</a></li>
                    <li><a asp-page="/Contact">Contact</a></li>
                </ul>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2025 - Razor Pages Essentials - <a asp-page="/Privacy">Privacy</a></p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
