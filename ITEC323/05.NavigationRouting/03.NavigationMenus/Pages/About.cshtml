@page
@model AboutModel
@{
    ViewData["Title"] = "About Navigation Menus";
}

<section class="p-4 bg-white border rounded-3 shadow-sm">
    <h2 class="h4">About this project</h2>
    <p class="mb-0">
        This stage of the module focuses on building professional navigation menus with Bootstrap.
        Students learn how to group links with dropdowns, keep navigation responsive, and
        highlight the current section.
    </p>
</section>

<section class="row g-3 mt-1">
    <article class="col-md-6">
        <div class="p-4 bg-white border rounded-3 shadow-sm h-100">
            <h3 class="h5">What this module emphasizes</h3>
            <ul class="mb-0">
                <li>Bootstrap navbar setup in shared layout</li>
                <li>Grouped links with dropdown menus</li>
                <li>Mobile collapse/toggler behavior</li>
                <li>Active link highlighting by current route</li>
            </ul>
        </div>
    </article>

    <article class="col-md-6">
        <div class="p-4 bg-white border rounded-3 shadow-sm h-100">
            <h3 class="h5">Quick links to test</h3>
            <ul class="mb-0">
                <li><a asp-page="/Products/Category" asp-route-name="Computers">Products dropdown item</a></li>
                <li><a asp-page="/Blog/Categories">Blog categories dropdown item</a></li>
                <li><a asp-page="/Blog/Archive" asp-route-year="2026">Blog archive dropdown item</a></li>
            </ul>
        </div>
    </article>
</section>

<section class="p-4 bg-white border rounded-3 shadow-sm mt-3">
    <h3 class="h5">Why menus matter</h3>
    <p class="mb-0">
        As projects grow, users need predictable navigation patterns. Well-structured menus improve discoverability,
        reduce confusion, and keep page hierarchy clear across screen sizes.
    </p>
    <div class="mt-3 d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-page="/Products/Index">Explore products section</a>
        <a class="btn btn-outline-primary" asp-page="/Blog/Index">Explore blog section</a>
        <a class="btn btn-outline-secondary" asp-page="/Contact">Open contact page</a>
    </div>
</section>