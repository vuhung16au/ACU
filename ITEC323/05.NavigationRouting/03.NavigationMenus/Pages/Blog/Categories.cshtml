@page
@model NavigationMenus.Pages.Blog.CategoriesModel
@{
    ViewData["Title"] = "Blog Categories";
}

<section class="p-4 bg-white border rounded-3 shadow-sm">
    <h2 class="h4">Blog Categories</h2>
    <p class="text-secondary">A dropdown child page used to demonstrate grouped menu navigation.</p>

    <div class="d-flex flex-wrap gap-2 mt-3">
        <span class="badge text-bg-primary">Routing Basics</span>
        <span class="badge text-bg-success">Tag Helpers</span>
        <span class="badge text-bg-warning">Bootstrap Menus</span>
        <span class="badge text-bg-info">Accessibility</span>
    </div>
</section>
