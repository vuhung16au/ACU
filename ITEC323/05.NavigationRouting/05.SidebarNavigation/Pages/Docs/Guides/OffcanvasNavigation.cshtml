@page
@model SidebarNavigation.Pages.Docs.Guides.OffcanvasNavigationModel
@{
    ViewData["Title"] = "Offcanvas Navigation";
}

<section class="hero-card mb-4">
    <h1 class="h3 mb-3">Offcanvas Navigation</h1>
    <p class="lead mb-2">
        Sidebars work well on wide screens, but on mobile they need to move out of the main content flow. Bootstrap Offcanvas handles that shift cleanly.
    </p>
    <p class="mb-0 text-secondary">
        Resize the browser and use the <strong>Menu</strong> button in the top bar to open the mobile version of the sidebar.
    </p>
</section>

<section class="content-card">
    <h2 class="h5">Why offcanvas matters</h2>
    <ul class="mb-0">
        <li>Preserves screen space for reading content.</li>
        <li>Keeps the same navigation items across desktop and mobile.</li>
        <li>Supports accessible open/close behavior with Bootstrap's built-in dialog pattern.</li>
        <li>Works well for documentation sites and admin dashboards.</li>
    </ul>
</section>
