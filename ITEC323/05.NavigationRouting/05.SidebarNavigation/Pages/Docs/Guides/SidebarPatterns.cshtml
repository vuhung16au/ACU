@page
@model SidebarNavigation.Pages.Docs.Guides.SidebarPatternsModel
@{
    ViewData["Title"] = "Sidebar Patterns";
}

<section class="hero-card mb-4">
    <h1 class="h3 mb-3">Sidebar Patterns</h1>
    <p class="lead mb-2">
        A good sidebar balances structure and restraint. It should reveal the current section without forcing users to scan a long, flat list.
    </p>
    <p class="mb-0 text-secondary">
        This page is part of a three-level navigation chain: Foundation -> Guides -> Sidebar Patterns.
    </p>
</section>

<section class="content-card">
    <h2 class="h5">Patterns shown in this project</h2>
    <ul class="mb-0">
        <li>Sticky desktop sidebar that remains visible while content scrolls.</li>
        <li>Collapsible section headings built with Bootstrap Collapse.</li>
        <li>Nested child links for deeper information architecture.</li>
        <li>Active-state styling that points to the current page.</li>
    </ul>
</section>
