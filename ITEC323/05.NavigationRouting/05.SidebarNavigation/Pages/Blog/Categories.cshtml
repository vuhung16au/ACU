@page
@model SidebarNavigation.Pages.Blog.CategoriesModel
@{
    ViewData["Title"] = "Blog Categories";
}

<section class="content-card mb-3">
    <h2 class="h4">Blog Categories</h2>
    <p class="text-secondary mb-0">A sidebar child page used to demonstrate grouped publishing navigation.</p>
</section>

<section class="row g-3">
    <div class="col-md-4">
        <div class="p-3 bg-white border rounded-3 h-100">
            <h3 class="h6">Routing</h3>
            <p class="mb-0 text-secondary">Friendly URLs, parameters, and route constraints.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-3 bg-white border rounded-3 h-100">
            <h3 class="h6">Navigation</h3>
            <p class="mb-0 text-secondary">Menus, breadcrumbs, and sidebar patterns.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-3 bg-white border rounded-3 h-100">
            <h3 class="h6">Accessibility</h3>
            <p class="mb-0 text-secondary">Accessible markup, labels, and current-page indicators.</p>
        </div>
    </div>
</section>
