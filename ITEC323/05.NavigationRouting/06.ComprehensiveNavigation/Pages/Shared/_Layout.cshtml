<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Comprehensive Navigation</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/06.ComprehensiveNavigation.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="bi bi-compass"></i> NavDemo
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    @await Component.InvokeAsync("NavigationMenu")
                    <form class="d-flex" method="post" asp-page="/Products/Search">
                        <input class="form-control me-2" type="search" placeholder="Search products..." aria-label="Search" name="searchTerm" required>
                        <button class="btn btn-outline-light" type="submit">Search</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-light border-top py-4 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5>About NavDemo</h5>
                    <p class="text-muted small">A comprehensive demonstration of navigation routing in ASP.NET Core Razor Pages.</p>
                </div>
                <div class="col-md-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled text-small">
                        <li><a class="text-decoration-none text-secondary" asp-page="/Index">Home</a></li>
                        <li><a class="text-decoration-none text-secondary" asp-page="/Products/Index">Products</a></li>
                        <li><a class="text-decoration-none text-secondary" asp-page="/Docs/Index">Documentation</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>Resources</h5>
                    <ul class="list-unstyled text-small">
                        <li><a class="text-decoration-none text-secondary" asp-page="/Account/Orders">My Account</a></li>
                        <li><a class="text-decoration-none text-secondary" href="/sitemap.xml">Sitemap XML</a></li>
                    </ul>
                </div>
            </div>
            <div class="text-center pt-3 text-muted small">
                &copy; 2026 - Comprehensive Navigation
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.css"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
