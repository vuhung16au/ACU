@page
@model ComprehensiveNavigation.Pages.Products.SearchModel
@{
    ViewData["Title"] = "Search Results";
}

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs")
    
    <div class="mb-4">
        <h1>Search Results</h1>
        <p class="lead">Results for query: <strong>@Model.SearchQuery</strong></p>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
            <div>
                No results found for "@Model.SearchQuery". Try another search term.
                <a asp-page="/Products/Index" class="alert-link ms-2">Browse all products</a>
            </div>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var product in Model.Products)
            {
                <a asp-page="/Products/Details" asp-route-id="@product.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@product.Name</h5>
                        <p class="mb-1 text-muted">@product.Description</p>
                        <small class="badge bg-secondary">@product.Category</small>
                    </div>
                    <span class="badge bg-success rounded-pill fs-6">@product.Price.ToString("C")</span>
                </a>
            }
        </div>
    }
</div>
