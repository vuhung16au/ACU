@page "{id:int}"
@model ComprehensiveNavigation.Pages.Products.DetailsModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product Not Found";
}

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs")
    
    @if (Model.Product == null)
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">Product Not Found</h4>
            <p>The product with ID @RouteData.Values["id"] could not be found.</p>
            <hr>
            <a asp-page="/Products/Index" class="btn btn-primary">Back to Products</a>
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@Model.Product.Name</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center mb-3">
                        <i class="bi bi-image fs-1 text-muted" style="font-size: 10rem;"></i>
                    </div>
                    <div class="col-md-8">
                        <h5 class="text-success fw-bold display-6">@Model.Product.Price.ToString("C")</h5>
                        <p class="mt-3">
                            <span class="badge bg-secondary mb-2">@Model.Product.Category</span>
                        </p>
                        <p class="lead">@Model.Product.Description</p>
                        <hr>
                        <p class="text-muted small">Product ID: @Model.Product.Id</p>
                        <button class="btn btn-success btn-lg disabled"><i class="bi bi-cart-plus"></i> Add to Cart (Demo)</button>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light">
                <a asp-page="/Products/Index" class="btn btn-outline-secondary">Back to Products</a>
                <a asp-page="/Products/Category" asp-route-category="@Model.Product.Category" class="btn btn-outline-info">View More @Model.Product.Category</a>
            </div>
        </div>
    }
</div>
