@page "{id:int}"
@model ComprehensiveNavigation.Pages.Account.OrderDetailsModel
@{
    ViewData["Title"] = $"Order #{Model.Order?.Id}";
}

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs")

    @if (Model.Order == null)
    {
        <div class="alert alert-danger">Order not found.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Order #@Model.Order.Id</h4>
                <span class="badge bg-@(Model.Order.Status == "Delivered" ? "success" : "primary") fs-6">@Model.Order.Status</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 border-end">
                        <h5>Order Summary</h5>
                        <p class="mb-1 text-muted">Placed on: @Model.Order.Date.ToString("f")</p>
                        <h4 class="mt-3 text-success">Total: @Model.Order.Total.ToString("C")</h4>
                    </div>
                    <div class="col-md-6">
                        <h5>Shipping Address</h5>
                        <p class="mb-0 text-muted">
                            123 Demo Street<br />
                            Tech City, TC 12345<br />
                            Australia
                        </p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white">
                <a asp-page="/Account/Orders" class="btn btn-outline-secondary">Back to Orders</a>
            </div>
        </div>
    }
</div>
